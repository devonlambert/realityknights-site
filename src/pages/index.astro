---
// index.astro — Reality Knights landing page
import Hero            from '../components/Hero.astro';
import VentureCard     from '../components/VentureCard.astro';
import About           from '../components/About.astro';
import InvestingSection from '../components/InvestingSection.astro';
import Footer          from '../components/Footer.astro';
import '../styles/global.css';

const ventures = [
  {
    title:       'Geeky Inc',
    tagline:     'Anime × Gaming × 3D Printing',
    description: 'A community-driven platform for gamers, otaku, and makers — bringing your favorite characters and moments to life through 3D printing. Collectibles, accessories, tutorials, and a sanctuary for people who wear their obsessions with pride.',
    accentColor: '#06B6D4',
    link:        'https://geekyinc.com',
    linkText:    'Visit Geeky Inc',
    status:      'Active',
  },
  {
    title:       'Lootsignal',
    tagline:     'AI-Powered Real Estate Discovery',
    description: 'Lootsignal surfaces real estate properties with high profit potential — then uses AI to assess the numbers before you ever make an offer. Currently paused. The idea is too good to kill.',
    accentColor: '#7C3AED',
    link:        'https://lootsignal.com',
    linkText:    'See the project',
    status:      'Paused',
  },
] as const;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Reality Knights LLC is a small holding company building products, platforms, and investments at the intersection of culture and technology." />
  <title>Reality Knights — Building things worth believing in</title>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Fonts: Outfit + Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- Open Graph -->
  <meta property="og:title"       content="Reality Knights — Building things worth believing in" />
  <meta property="og:description" content="Reality Knights LLC is a small holding company building products, platforms, and investments at the intersection of culture and technology." />
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content="https://realityknights.com" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary" />
  <meta name="twitter:title"       content="Reality Knights — Building things worth believing in" />
  <meta name="twitter:description" content="A small holding company with big taste. Building Geeky Inc, Lootsignal, and more." />
</head>

<body class="bg-rk-bg text-rk-text">

  <!-- ── Hero ───────────────────────────────────────────── -->
  <Hero />

  <!-- ── Ventures ───────────────────────────────────────── -->
  <section class="py-24 px-6" id="ventures">
    <div class="max-w-5xl mx-auto">

      <!-- Section header -->
      <div class="mb-14">
        <p class="font-inter text-rk-muted text-xs tracking-[0.25em] uppercase mb-3 font-medium">
          What we're building
        </p>
        <h2
          class="font-outfit text-rk-text leading-tight"
          style="font-size: clamp(1.8rem, 4vw, 2.75rem); font-weight: 700;"
        >
          The Portfolio
        </h2>
      </div>

      <!-- Card grid: 2-col desktop, 1-col mobile -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {ventures.map((v) => (
          <VentureCard
            title={v.title}
            tagline={v.tagline}
            description={v.description}
            accentColor={v.accentColor}
            link={v.link}
            linkText={v.linkText}
            status={v.status}
          />
        ))}
      </div>

    </div>
  </section>

  <!-- ── About ─────────────────────────────────────────── -->
  <About />

  <!-- ── Investing / Capital ─────────────────────────────── -->
  <InvestingSection />

  <!-- ── Footer ─────────────────────────────────────────── -->
  <Footer />

</body>
</html>
